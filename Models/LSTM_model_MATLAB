function y = lstmOutputFcnFast(h, u)%#ok<INUSD>
% lstmOutputFcnFast
% Output function for rebuilt PyTorch LSTM

persistent P S
if isempty(P)
    P =load("LSTM_params.mat");
    S=load("scalars.mat");

    S.X_mean=S.X_mean(:);
    S.X_scale=S.X_scale(:);
end

H = 128;
L = 3;

h = double(h(:));


startIdx = (L-1)*H + 1;
h3 = h(startIdx:startIdx+H-1);

Wout = double(P.fc_weight);   % 6 x 128
bout = double(P.fc_bias(:));  % 6x1

y_norm = Wout*h3 + bout;                  % 6x1
y = y_norm.*S.Y_scale(:)+S.Y_mean(:);
y = double(y);
end
